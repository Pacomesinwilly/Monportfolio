{
  "name": "Monportfolio",
  "description": "Portfolio professionnel avec React, Vite et Tailwind CSS",
  "keywords": ["react", "vite", "portfolio", "tailwindcss"],
  "env": {
    "NODE_ENV": {
      "description": "Environment de l'application",
      "value": "production"
    },
    "NODE_VERSION": {
      "description": "Version de Node.js",
      "value": "20"
    }
  },
  "buildCommand": "npm ci && npm run build",
  "startCommand": "npm install -g serve && serve -s dist -l 3000"
}
